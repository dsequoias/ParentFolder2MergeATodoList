{
  "expo": {
    "name": "DailyDuty",
    "slug": "DailyDuty",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ddicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dosDailyDuty",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.dosDailyDuty",
      "adaptiveIcon": {
        "foregroundImage": "./assets/ddicon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "defaultChannel": "todo-reminders"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/ddicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "320eade3-887c-473a-afa1-47404ce4a9e9"
      }
    }
  }
}
