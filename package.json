{
  "name": "DailyDuty",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --web",
    "android": "node scripts/patch-gradle-react-format.mjs && expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile production",
    "fix-icon": "node scripts/fix-icon.mjs",
    "copy-icons": "node scripts/copy-icons-from-new.mjs",
    "remove-icon-bg": "node scripts/remove-icon-white-background.mjs",
    "prepare": "node scripts/create-reminder-sound.js",
    "postinstall": "patch-package",
    "test": "node scripts/verify-reminder-utils.mjs"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-dev-client": "~6.0.20",
    "expo-haptics": "~15.0.8",
    "expo-intent-launcher": "~13.0.8",
    "expo-notifications": "^0.32.16",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "babel-preset-expo": "~54.0.10",
    "patch-package": "^8.0.1",
    "sharp": "^0.33.5"
  },
  "private": true
}
